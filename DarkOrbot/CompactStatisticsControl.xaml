<Window x:Class="DarkOrbot.CompactStatisticsControl"
         xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
         xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
         xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
         xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
         xmlns:scm="clr-namespace:System.ComponentModel;assembly=WindowsBase"
         xmlns:obj="clr-namespace:DarksideApi.DarkOrbit;assembly=DarksideApi"
         xmlns:hlp="clr-namespace:DarkOrbot.Util"
         xmlns:stats="clr-namespace:DarksideApi.Statistics;assembly=DarksideApi"
         xmlns:cmds="clr-namespace:DarksideApi.DarkOrbit.Commands;assembly=DarksideApi"
         xmlns:settings="clr-namespace:DarksideApi.DarkOrbit.Settings;assembly=DarksideApi"
         xmlns:local="clr-namespace:DarkOrbot"
         mc:Ignorable="d" d:DesignWidth="707" Height="740" Width="707" IsVisibleChanged="Window_IsVisibleChanged" Loaded="Window_Loaded" Unloaded="Window_Unloaded"  AllowsTransparency="True" Background="#1d1d1f"
DataContext="{Binding RelativeSource={RelativeSource Self}}" VerticalAlignment="Stretch" HorizontalAlignment="Stretch" WindowStyle="None"  ShowInTaskbar="False">
    <Window.Resources>

        <BooleanToVisibilityConverter x:Key="BoolToVis" />

        <Style TargetType="{x:Type ToolTip}">
            <Setter Property="Background" Value="#FF040406" />
            <Setter Property="Foreground" Value="White" />
        </Style>

        <Style TargetType="Button" x:Name="RoundedCornerBtn" x:Key="RoundedCornerBtn">
            <Style.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="5"/>
                </Style>
            </Style.Resources>
        </Style>

        <Style TargetType="{x:Type TabItem}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type TabItem}">
                        <Grid>
                            <Border Name="Border" Margin="0,0,0,0" Background="Black"
BorderBrush="White" BorderThickness="1,1,1,1" CornerRadius="5">
                                <ContentPresenter x:Name="ContentSite" VerticalAlignment="Center"
            HorizontalAlignment="Center"
            ContentSource="Header" Margin="12,2,12,2"
            RecognizesAccessKey="True">
                                </ContentPresenter>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Panel.ZIndex" Value="100" />
                                <Setter TargetName="Border" Property="Background" Value="Gray" />
                                <Setter TargetName="Border" Property="BorderThickness" Value="1,1,1,1" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="False">
                                <Setter Property="Foreground" Value="Gray" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style BasedOn="{StaticResource {x:Type DataGridColumnHeader}}" TargetType="{x:Type DataGridColumnHeader}">
            <Setter Property="Background" >
                <Setter.Value>
                    <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                        <GradientStop Color="Black" Offset="0.9"/>
                        <GradientStop Color="#FF030304" Offset="1"/>
                        <GradientStop Color="Black" Offset="0"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ScrollBarLineButton" TargetType="{x:Type RepeatButton}">
            <Setter Property="Visibility" Value="Hidden"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="OverridesDefaultStyle" Value="true"/>
            <Setter Property="Focusable" Value="false"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type RepeatButton}">
                        <Border Name="Border" Margin="1" CornerRadius="2" Background="#7F040406" BorderBrush="Gray" BorderThickness="1">
                            <Path HorizontalAlignment="Center" VerticalAlignment="Center" Fill="White" Data="{Binding Path=Content, RelativeSource={RelativeSource TemplatedParent}}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsPressed" Value="true">
                                <Setter TargetName="Border" Property="Background" Value="WhiteSmoke" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="false">
                                <Setter Property="Foreground" Value="DarkGray"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ScrollBarPageButton" TargetType="{x:Type RepeatButton}">
            <Setter Property="Visibility" Value="Hidden"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="OverridesDefaultStyle" Value="true"/>
            <Setter Property="IsTabStop" Value="false"/>
            <Setter Property="Focusable" Value="false"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type RepeatButton}">
                        <Border Background="DimGray" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ScrollBarThumb" TargetType="{x:Type Thumb}">
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="OverridesDefaultStyle" Value="true"/>
            <Setter Property="IsTabStop" Value="false"/>
            <Setter Property="Focusable" Value="false"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Thumb}">
                        <Border CornerRadius="4" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="0"  Width="8" Margin="8,0,-2,0"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <ControlTemplate x:Key="VerticalScrollBar" TargetType="{x:Type ScrollBar}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition MaxHeight="0"/>
                    <RowDefinition Height="0.00001*"/>
                    <RowDefinition MaxHeight="0"/>
                </Grid.RowDefinitions>
                <Border Grid.RowSpan="3" CornerRadius="2" Background="Transparent" />
                <RepeatButton Grid.Row="0" Style="{StaticResource ScrollBarLineButton}" Height="18" Command="ScrollBar.LineUpCommand" Content="M 0 4 L 8 4 L 4 0 Z" />
                <Track Name="PART_Track" Grid.Row="1" IsDirectionReversed="true">
                    <Track.DecreaseRepeatButton>
                        <RepeatButton Style="{StaticResource ScrollBarPageButton}" Command="ScrollBar.PageUpCommand" />
                    </Track.DecreaseRepeatButton>
                    <Track.Thumb>
                        <Thumb Style="{StaticResource ScrollBarThumb}" Margin="1,0,1,0" Background="#1b82e3" BorderBrush="Gray" />
                    </Track.Thumb>
                    <Track.IncreaseRepeatButton>
                        <RepeatButton Style="{StaticResource ScrollBarPageButton}" Command="ScrollBar.PageDownCommand" />
                    </Track.IncreaseRepeatButton>
                </Track>
                <RepeatButton Grid.Row="3" Style="{StaticResource ScrollBarLineButton}" Height="18" Command="ScrollBar.LineDownCommand" Content="M 0 0 L 4 4 L 8 0 Z"/>
            </Grid>
        </ControlTemplate>
        <ControlTemplate x:Key="HorizontalScrollBar" TargetType="{x:Type ScrollBar}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition MaxWidth="18"/>
                    <ColumnDefinition Width="0.00001*"/>
                    <ColumnDefinition MaxWidth="18"/>
                </Grid.ColumnDefinitions>
                <Border Grid.ColumnSpan="3" CornerRadius="2" Background="Transparent"/>
                <RepeatButton Grid.Column="0"  Style="{StaticResource ScrollBarLineButton}" Width="18" Command="ScrollBar.LineLeftCommand" Content="M 4 0 L 4 8 L 0 4 Z" />
                <Track Name="PART_Track" Grid.Column="1" IsDirectionReversed="False">
                    <Track.DecreaseRepeatButton>
                        <RepeatButton Style="{StaticResource ScrollBarPageButton}" Command="ScrollBar.PageLeftCommand" />
                    </Track.DecreaseRepeatButton>
                    <Track.Thumb>
                        <Thumb Style="{StaticResource ScrollBarThumb}" Margin="0,1,0,1" Background="#1b82e3" BorderBrush="Gray" />
                    </Track.Thumb>
                    <Track.IncreaseRepeatButton>
                        <RepeatButton Style="{StaticResource ScrollBarPageButton}" Command="ScrollBar.PageRightCommand" />
                    </Track.IncreaseRepeatButton>
                </Track>
                <RepeatButton Grid.Column="3" Style="{StaticResource ScrollBarLineButton}" Width="18" Command="ScrollBar.LineRightCommand" Content="M 0 0 L 4 4 L 0 8 Z"/>
            </Grid>
        </ControlTemplate>
        <Style x:Key="{x:Type ScrollBar}" TargetType="{x:Type ScrollBar}">
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="OverridesDefaultStyle" Value="true"/>
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Horizontal">
                    <Setter Property="Width" Value="Auto"/>
                    <Setter Property="Height" Value="12" />
                    <Setter Property="Template" Value="{StaticResource HorizontalScrollBar}" />
                </Trigger>
                <Trigger Property="Orientation" Value="Vertical">
                    <Setter Property="Width" Value="18"/>
                    <Setter Property="Height" Value="Auto" />
                    <Setter Property="Template" Value="{StaticResource VerticalScrollBar}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="FavsScrollViewer" TargetType="{x:Type ScrollViewer}">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ScrollViewer}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <ScrollContentPresenter Grid.Column="1"/>
                            <ScrollBar Name="PART_VerticalScrollBar" Value="{TemplateBinding VerticalOffset}" Maximum="{TemplateBinding ScrollableHeight}" ViewportSize="{TemplateBinding ViewportHeight}" Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"/>
                            <ScrollBar Name="PART_HorizontalScrollBar" Orientation="Horizontal" Grid.Row="1" Grid.Column="1" Value="{TemplateBinding HorizontalOffset}" Maximum="{TemplateBinding ScrollableWidth}" ViewportSize="{TemplateBinding ViewportWidth}" Visibility="{TemplateBinding ComputedHorizontalScrollBarVisibility}"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="{x:Type ContextMenu}">
            <Setter Property="Background" Value="#FF040406" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Opacity" Value="75" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="OverridesDefaultStyle" Value="True" />
            <Setter Property="HasDropShadow" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ContextMenu}">
                        <Border x:Name="Border" Background="{TemplateBinding Background}" BorderBrush="Gray" Opacity="{TemplateBinding Opacity}" BorderThickness="0.5" CornerRadius="3">
                            <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Cycle">
                            </StackPanel>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="{x:Type MenuItem}">
            <Setter Property="Background" Value="#FF040406" />
            <Setter Property="BorderThickness" Value="0.5" />
            <Setter Property="BorderBrush" Value="Gray" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type MenuItem}">
                        <Grid SnapsToDevicePixels="true">
                            <Border BorderBrush="Gray" BorderThickness="0.5" CornerRadius="3">

                                <DockPanel>
                                    <ContentPresenter x:Name="Icon" ContentSource="Icon" Margin="4,0,6,0" SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" VerticalAlignment="Center" />
                                    <Path x:Name="GlyphPanel" Fill="{TemplateBinding Foreground}" FlowDirection="LeftToRight" Margin="7,0,0,0" Visibility="Collapsed" VerticalAlignment="Center" />
                                    <ContentPresenter x:Name="content" ContentSource="Header" RecognizesAccessKey="True" SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                                </DockPanel>
                            </Border>
                            <Popup x:Name="PART_Popup" AllowsTransparency="true" Focusable="false" IsOpen="{Binding IsSubmenuOpen, RelativeSource={RelativeSource TemplatedParent}}" PopupAnimation="{DynamicResource {x:Static SystemParameters.MenuPopupAnimationKey}}" Placement="Bottom" VerticalOffset="-1">
                                <Border BorderThickness="0.5" BorderBrush="Gray" Background="#FF040406">
                                    <ScrollViewer x:Name="SubMenuScrollViewer" CanContentScroll="true" Style="{DynamicResource {ComponentResourceKey ResourceId=MenuScrollViewer, TypeInTargetAssembly={x:Type FrameworkElement}}}">
                                        <Grid RenderOptions.ClearTypeHint="Enabled">
                                            <ItemsPresenter x:Name="ItemsPresenter" KeyboardNavigation.DirectionalNavigation="Cycle" Grid.IsSharedSizeScope="true" Margin="2" SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" KeyboardNavigation.TabNavigation="Cycle" />
                                        </Grid>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True" />
                                    <Condition Property="IsChecked" Value="True" />
                                </MultiTrigger.Conditions>
                                <Setter Property="TextBlock.Foreground" Value="Green" TargetName="content" />
                            </MultiTrigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="TextBlock.Foreground" Value="LightGray" TargetName="content" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="TextBlock.Foreground" Value="SpringGreen" TargetName="content" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>
    <Border BorderBrush="#1b82e3" BorderThickness="0.5">
        <Grid>
            <Button x:Name="closeBtn" Style="{StaticResource RoundedCornerBtn}" BorderThickness="1" BorderBrush="White" HorizontalAlignment="Right" Height="25" VerticalAlignment="Top" Width="25" Foreground="{x:Null}" Click="closeBtn_Click" ToolTip="Close" Margin="0,5,5,0">
                <Button.Background>
                    <ImageBrush ImageSource="/Icons/closeIco.png"/>
                </Button.Background>
            </Button>
            <Grid Margin="0,30,0,0">
                <GroupBox x:Name="resourcesGroupBox" Header="Resources" Margin="477,10,10,316" Foreground="White">
                    <DataGrid x:Name="resourcesDataGrid" ItemsSource="{Binding Api.Statistics.ResourcesStatistics}" Margin="0,0,-2,0" Background="#00F0F0F0" RowBackground="#00F0F0F0" AlternatingRowBackground="#00F0F0F0" BorderBrush="#00688CAF" CanUserReorderColumns="False" CanUserSortColumns="False" Foreground="White" FontWeight="Bold" AutoGenerateColumns="False" CanUserAddRows="False" HeadersVisibility="Column" GridLinesVisibility="None" Height="351" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Auto">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Resource" CanUserResize="True" Width="25*" Binding="{Binding Name}" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Amount" CanUserResize="True" Width="20*" Binding="{Binding AmountString}" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Per Hour" CanUserResize="True" Width="20*" Binding="{Binding PerHourString}" IsReadOnly="True"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </GroupBox>
                <GroupBox x:Name="boxesGroupBox" Header="Boxes" Margin="10,321,480,40" Foreground="White">
                    <DataGrid x:Name="boxesDataGrid" ItemsSource="{Binding Api.Statistics.BoxStatistics}" Margin="0,0,-2,0" Background="#00F0F0F0" RowBackground="#00F0F0F0" AlternatingRowBackground="#00F0F0F0" BorderBrush="#00688CAF" CanUserReorderColumns="False" CanUserSortColumns="False" Foreground="White" FontWeight="Bold" AutoGenerateColumns="False" CanUserAddRows="False" HeadersVisibility="Column" GridLinesVisibility="None" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Auto">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Box" CanUserResize="True" Width="25*" Binding="{Binding Name}" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Amount" CanUserResize="True" Width="20*" Binding="{Binding AmountString}" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Per Hour" CanUserResize="True" Width="20*" Binding="{Binding PerHourString}" IsReadOnly="True"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </GroupBox>
                <GroupBox x:Name="generalGroupBox" Header="General" Margin="10,10,479,388" Foreground="White">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="282*"/>
                            <ColumnDefinition Width="395*"/>
                        </Grid.ColumnDefinitions>
                        <Label x:Name="generalCreditsDescLabel" Content="+Credits:" HorizontalAlignment="Left" Foreground="White" Margin="10,10,0,0" VerticalAlignment="Top"/>
                        <Label x:Name="generalCreditsTotalDescLabel" Content="Total:" HorizontalAlignment="Left" Foreground="White" Margin="19,42,0,0" VerticalAlignment="Top"/>
                        <Label x:Name="generalCreditsAmountLabel" d:Content="+1000" Content="{Binding Api.Statistics.CollectedCredits.FullString}" HorizontalAlignment="Left" Foreground="White" Margin="10,10,0,0" VerticalAlignment="Top" Grid.Column="1"/>
                        <Label x:Name="generalCreditsTotalAmountLabel" d:Content="+1000" Content="{Binding Api.Statistics.CollectedCredits.TotalString}" HorizontalAlignment="Left" Foreground="White" Margin="10,42,0,0" VerticalAlignment="Top" Grid.Column="1"/>
                        <Label x:Name="generalUridiumDescLabel" Content="+Uridium:" HorizontalAlignment="Center" Foreground="White" Margin="0,71,0,0" VerticalAlignment="Top"/>
                        <Label x:Name="generalUridiumTotalDescLabel" Content="Total:" HorizontalAlignment="Left" Foreground="White" Margin="19,103,0,0" VerticalAlignment="Top"/>
                        <Label x:Name="generalUridiumAmountLabel" d:Content="+1000" Content="{Binding Api.Statistics.CollectedUridium.FullString}" HorizontalAlignment="Left" Foreground="White" Margin="10,71,0,0" VerticalAlignment="Top" Grid.Column="1"/>
                        <Label x:Name="generalUridiumTotalAmountLabel" d:Content="+1000" Content="{Binding Api.Statistics.CollectedUridium.TotalString}" HorizontalAlignment="Left" Foreground="White" Margin="10,103,0,0" VerticalAlignment="Top" Grid.Column="1"/>
                        <Label x:Name="generalXPDescLabel" Content="+XP:" HorizontalAlignment="Left" Foreground="White" Margin="10,134,0,0" VerticalAlignment="Top"/>
                        <Label x:Name="generalXPAmountLabel" d:Content="+1000" Content="{Binding Api.Statistics.CollectedXP.FullString}" HorizontalAlignment="Left" Foreground="White" Margin="10,134,0,0" VerticalAlignment="Top" Grid.Column="1"/>
                        <Label x:Name="generalHonorDescLabel" Content="+Honor:" HorizontalAlignment="Left" Foreground="White" Margin="10,165,0,0" VerticalAlignment="Top"/>
                        <Label x:Name="generalHonorAmountLabel" d:Content="+1000" Content="{Binding Api.Statistics.CollectedHonor.FullString}" HorizontalAlignment="Left" Foreground="White" Margin="10,165,0,0" VerticalAlignment="Top" Grid.Column="1"/>
                        <Label x:Name="generalEEDescLabel" Content="+EE:" HorizontalAlignment="Left" Foreground="White" Margin="10,196,0,0" VerticalAlignment="Top"/>
                        <Label x:Name="generalEEAmountLabel" d:Content="+1000" Content="{Binding Api.Statistics.CollectedEE.FullString}" HorizontalAlignment="Left" Foreground="White" Margin="10,196,0,0" VerticalAlignment="Top" Grid.Column="1"/>
                    </Grid>
                </GroupBox>
                <GroupBox x:Name="npcsGroupBox" Header="Npcs" Margin="233,10,235,388" Foreground="White">
                    <DataGrid x:Name="npcsDataGrid" ItemsSource="{Binding Api.Statistics.NpcStatistics}" Margin="0,0,-2,0" Background="#00F0F0F0" RowBackground="#00F0F0F0" AlternatingRowBackground="#00F0F0F0" BorderBrush="#00688CAF" CanUserReorderColumns="False" CanUserSortColumns="False" Foreground="White" FontWeight="Bold" AutoGenerateColumns="False" CanUserAddRows="False" HeadersVisibility="Column" GridLinesVisibility="None" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Auto">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Npc" CanUserResize="True" Width="40*" Binding="{Binding Name}" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Amount" CanUserResize="True" Width="20*" Binding="{Binding AmountString}" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Per Hour" CanUserResize="True" Width="20*" Binding="{Binding PerHourString}" IsReadOnly="True"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </GroupBox>
                <GroupBox x:Name="activitiesGroupBox" Header="Activities" Margin="234,321,233,40" Foreground="White">
                    <Grid>
                        <Label x:Name="activitiesPlayersDestroyedDescLabel" Content="Players Destroyed:" HorizontalAlignment="Left" Foreground="White" Margin="10,10,0,0" VerticalAlignment="Top"/>
                        <Label x:Name="activitiesPlayersDestroyedAmountLabel" d:Content="10" Content="{Binding Api.Statistics.AmountPlayersDestroyed.FullString}" HorizontalAlignment="Left" Foreground="White" Margin="114,10,0,0" VerticalAlignment="Top"/>
                        <Label x:Name="activitiesFledDescLabel" Content="Fled:" HorizontalAlignment="Left" Foreground="White" Margin="10,41,0,0" VerticalAlignment="Top"/>
                        <Label x:Name="activitiesFledAmountLabel" d:Content="10" Content="{Binding Api.Statistics.AmountFled.FullString}" HorizontalAlignment="Left" Foreground="White" Margin="114,41,0,0" VerticalAlignment="Top"/>
                        <Label x:Name="activitiesShotbackDescLabel" Content="Shotback:" HorizontalAlignment="Left" Foreground="White" Margin="10,72,0,0" VerticalAlignment="Top"/>
                        <Label x:Name="activitiesShotbackAmountLabel" d:Content="10" Content="{Binding Api.Statistics.AmountShotback.FullString}" HorizontalAlignment="Left" Foreground="White" Margin="114,72,0,0" VerticalAlignment="Top"/>
                        <Label x:Name="activitiesTradesDescLabel" Content="Trades:" HorizontalAlignment="Left" Foreground="White" Margin="11,103,0,0" VerticalAlignment="Top"/>
                        <Label x:Name="activitiesTradesAmountLabel" d:Content="10" Content="{Binding Api.Statistics.AmountTrades.FullString}" HorizontalAlignment="Left" Foreground="White" Margin="114,103,0,0" VerticalAlignment="Top"/>

                    </Grid>
                </GroupBox>
                <Button x:Name="generalResetStatsBtn" Content="Reset Statistics" HorizontalAlignment="Center" Margin="0,669,0,0" VerticalAlignment="Top" Width="687" Foreground="White" Background="Black" Click="generalResetStatsBtn_Click" Height="25">
                    <Button.Resources>
                        <Style TargetType="{x:Type Border}">
                            <Setter Property="CornerRadius" Value="3"/>
                        </Style>
                    </Button.Resources>
                </Button>
                <GroupBox x:Name="deathsGroupBox" Header="Deaths" Margin="479,393,10,40" Foreground="White">
                    <DataGrid x:Name="deathsDataGrid" ItemsSource="{Binding Api.Statistics.DeathsStatistics}" Margin="0,0,-2,0" Background="#00F0F0F0" RowBackground="#00F0F0F0" AlternatingRowBackground="#00F0F0F0" BorderBrush="#00688CAF" CanUserReorderColumns="False" CanUserSortColumns="False" Foreground="White" FontWeight="Bold" AutoGenerateColumns="False" CanUserAddRows="False" HeadersVisibility="Column" GridLinesVisibility="None" Height="239" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Auto">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="By" CanUserResize="True" Width="30*" Binding="{Binding Name}" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Amount" CanUserResize="True" Width="15*" Binding="{Binding AmountString}" IsReadOnly="True"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </GroupBox>
            </Grid>
        </Grid>
    </Border>
</Window>
