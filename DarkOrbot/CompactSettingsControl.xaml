<Window x:Class="DarkOrbot.CompactSettingsControl"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
         xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
         xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
         xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
         xmlns:scm="clr-namespace:System.ComponentModel;assembly=WindowsBase"
         xmlns:obj="clr-namespace:DarksideApi.DarkOrbit;assembly=DarksideApi"
         xmlns:hlp="clr-namespace:DarkOrbot.Util"
         xmlns:stats="clr-namespace:DarksideApi.Statistics;assembly=DarksideApi"
         xmlns:cmds="clr-namespace:DarksideApi.DarkOrbit.Commands;assembly=DarkOrbitProtoLib"
         xmlns:cnst="clr-namespace:DarksideApi.DarkOrbit.Constants;assembly=DarksideApi"
         xmlns:settings="clr-namespace:DarksideApi.DarkOrbit.Settings;assembly=DarksideApi"
         xmlns:local="clr-namespace:DarkOrbot"
         mc:Ignorable="d"
         d:DesignHeight="750" d:DesignWidth="707" Height="750" Width="707" IsVisibleChanged="Window_IsVisibleChanged" Loaded="UserControl_Loaded" Unloaded="UserControl_Unloaded" Background="#1d1d1f"
DataContext="{Binding RelativeSource={RelativeSource Self}}" VerticalAlignment="Stretch" HorizontalAlignment="Stretch" WindowStyle="None"  ShowInTaskbar="False">
    <Window.Resources>

        <BooleanToVisibilityConverter x:Key="BoolToVis" />

        <Style TargetType="{x:Type ToolTip}">
            <Setter Property="Background" Value="#FF040406" />
            <Setter Property="Foreground" Value="White" />
        </Style>

        <Style TargetType="Button" x:Name="RoundedCornerBtn" x:Key="RoundedCornerBtn">
            <Style.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="5"/>
                </Style>
            </Style.Resources>
        </Style>

        <Style TargetType="{x:Type TabItem}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type TabItem}">
                        <Grid>
                            <Border Name="Border" Margin="0,0,0,0" Background="Black"
BorderBrush="White" BorderThickness="1,1,1,1" CornerRadius="5">
                                <ContentPresenter x:Name="ContentSite" VerticalAlignment="Center"
            HorizontalAlignment="Center"
            ContentSource="Header" Margin="12,2,12,2"
            RecognizesAccessKey="True" MinHeight="16">
                                </ContentPresenter>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Panel.ZIndex" Value="100" />
                                <Setter TargetName="Border" Property="Background" Value="#1d1d1f" />
                                <Setter TargetName="Border" Property="BorderThickness" Value="1,1,1,1" />
                                <Setter Property="Foreground" Value="#1b82e3" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="False">
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style BasedOn="{StaticResource {x:Type DataGridColumnHeader}}" TargetType="{x:Type DataGridColumnHeader}">
            <Setter Property="Background" >
                <Setter.Value>
                    <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                        <GradientStop Color="Black" Offset="0.9"/>
                        <GradientStop Color="#FF030304" Offset="1"/>
                        <GradientStop Color="Black" Offset="0"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ScrollBarLineButton" TargetType="{x:Type RepeatButton}">
            <Setter Property="Visibility" Value="Hidden"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="OverridesDefaultStyle" Value="true"/>
            <Setter Property="Focusable" Value="false"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type RepeatButton}">
                        <Border Name="Border" Margin="1" CornerRadius="2" Background="#7F040406" BorderBrush="Gray" BorderThickness="1">
                            <Path HorizontalAlignment="Center" VerticalAlignment="Center" Fill="White" Data="{Binding Path=Content, RelativeSource={RelativeSource TemplatedParent}}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsPressed" Value="true">
                                <Setter TargetName="Border" Property="Background" Value="WhiteSmoke" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="false">
                                <Setter Property="Foreground" Value="DarkGray"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ScrollBarPageButton" TargetType="{x:Type RepeatButton}">
            <Setter Property="Visibility" Value="Hidden"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="OverridesDefaultStyle" Value="true"/>
            <Setter Property="IsTabStop" Value="false"/>
            <Setter Property="Focusable" Value="false"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type RepeatButton}">
                        <Border Background="DimGray" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ScrollBarThumb" TargetType="{x:Type Thumb}">
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="OverridesDefaultStyle" Value="true"/>
            <Setter Property="IsTabStop" Value="false"/>
            <Setter Property="Focusable" Value="false"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Thumb}">
                        <Border CornerRadius="4" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="0"  Width="8" Margin="8,0,-2,0"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <ControlTemplate x:Key="VerticalScrollBar" TargetType="{x:Type ScrollBar}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition MaxHeight="0"/>
                    <RowDefinition Height="0.00001*"/>
                    <RowDefinition MaxHeight="0"/>
                </Grid.RowDefinitions>
                <Border Grid.RowSpan="3" CornerRadius="2" Background="Transparent" />
                <RepeatButton Grid.Row="0" Style="{StaticResource ScrollBarLineButton}" Height="18" Command="ScrollBar.LineUpCommand" Content="M 0 4 L 8 4 L 4 0 Z" />
                <Track Name="PART_Track" Grid.Row="1" IsDirectionReversed="true">
                    <Track.DecreaseRepeatButton>
                        <RepeatButton Style="{StaticResource ScrollBarPageButton}" Command="ScrollBar.PageUpCommand" />
                    </Track.DecreaseRepeatButton>
                    <Track.Thumb>
                        <Thumb Style="{StaticResource ScrollBarThumb}" Margin="1,0,1,0" Background="#1b82e3" BorderBrush="Gray" />
                    </Track.Thumb>
                    <Track.IncreaseRepeatButton>
                        <RepeatButton Style="{StaticResource ScrollBarPageButton}" Command="ScrollBar.PageDownCommand" />
                    </Track.IncreaseRepeatButton>
                </Track>
                <RepeatButton Grid.Row="3" Style="{StaticResource ScrollBarLineButton}" Height="18" Command="ScrollBar.LineDownCommand" Content="M 0 0 L 4 4 L 8 0 Z"/>
            </Grid>
        </ControlTemplate>
        <ControlTemplate x:Key="HorizontalScrollBar" TargetType="{x:Type ScrollBar}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition MaxWidth="18"/>
                    <ColumnDefinition Width="0.00001*"/>
                    <ColumnDefinition MaxWidth="18"/>
                </Grid.ColumnDefinitions>
                <Border Grid.ColumnSpan="3" CornerRadius="2" Background="Transparent"/>
                <RepeatButton Grid.Column="0"  Style="{StaticResource ScrollBarLineButton}" Width="18" Command="ScrollBar.LineLeftCommand" Content="M 4 0 L 4 8 L 0 4 Z" />
                <Track Name="PART_Track" Grid.Column="1" IsDirectionReversed="False">
                    <Track.DecreaseRepeatButton>
                        <RepeatButton Style="{StaticResource ScrollBarPageButton}" Command="ScrollBar.PageLeftCommand" />
                    </Track.DecreaseRepeatButton>
                    <Track.Thumb>
                        <Thumb Style="{StaticResource ScrollBarThumb}" Margin="0,1,0,1" Background="#1b82e3" BorderBrush="Gray" />
                    </Track.Thumb>
                    <Track.IncreaseRepeatButton>
                        <RepeatButton Style="{StaticResource ScrollBarPageButton}" Command="ScrollBar.PageRightCommand" />
                    </Track.IncreaseRepeatButton>
                </Track>
                <RepeatButton Grid.Column="3" Style="{StaticResource ScrollBarLineButton}" Width="18" Command="ScrollBar.LineRightCommand" Content="M 0 0 L 4 4 L 0 8 Z"/>
            </Grid>
        </ControlTemplate>
        <Style x:Key="{x:Type ScrollBar}" TargetType="{x:Type ScrollBar}">
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="OverridesDefaultStyle" Value="true"/>
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Horizontal">
                    <Setter Property="Width" Value="Auto"/>
                    <Setter Property="Height" Value="12" />
                    <Setter Property="Template" Value="{StaticResource HorizontalScrollBar}" />
                </Trigger>
                <Trigger Property="Orientation" Value="Vertical">
                    <Setter Property="Width" Value="18"/>
                    <Setter Property="Height" Value="Auto" />
                    <Setter Property="Template" Value="{StaticResource VerticalScrollBar}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="FavsScrollViewer" TargetType="{x:Type ScrollViewer}">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ScrollViewer}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <ScrollContentPresenter Grid.Column="1"/>
                            <ScrollBar Name="PART_VerticalScrollBar" Value="{TemplateBinding VerticalOffset}" Maximum="{TemplateBinding ScrollableHeight}" ViewportSize="{TemplateBinding ViewportHeight}" Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"/>
                            <ScrollBar Name="PART_HorizontalScrollBar" Orientation="Horizontal" Grid.Row="1" Grid.Column="1" Value="{TemplateBinding HorizontalOffset}" Maximum="{TemplateBinding ScrollableWidth}" ViewportSize="{TemplateBinding ViewportWidth}" Visibility="{TemplateBinding ComputedHorizontalScrollBarVisibility}"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="{x:Type ContextMenu}">
            <Setter Property="Background" Value="#FF040406" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Opacity" Value="75" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="OverridesDefaultStyle" Value="True" />
            <Setter Property="HasDropShadow" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ContextMenu}">
                        <Border x:Name="Border" Background="{TemplateBinding Background}" BorderBrush="Gray" Opacity="{TemplateBinding Opacity}" BorderThickness="0.5" CornerRadius="3">
                            <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Cycle">
                            </StackPanel>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="{x:Type MenuItem}">
            <Setter Property="Background" Value="#FF040406" />
            <Setter Property="BorderThickness" Value="0.5" />
            <Setter Property="BorderBrush" Value="Gray" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type MenuItem}">
                        <Grid SnapsToDevicePixels="true">
                            <Border BorderBrush="Gray" BorderThickness="0.5" CornerRadius="3">

                                <DockPanel>
                                    <ContentPresenter x:Name="Icon" ContentSource="Icon" Margin="4,0,6,0" SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" VerticalAlignment="Center" />
                                    <Path x:Name="GlyphPanel" Fill="{TemplateBinding Foreground}" FlowDirection="LeftToRight" Margin="7,0,0,0" Visibility="Collapsed" VerticalAlignment="Center" />
                                    <ContentPresenter x:Name="content" ContentSource="Header" RecognizesAccessKey="True" SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                                </DockPanel>
                            </Border>
                            <Popup x:Name="PART_Popup" AllowsTransparency="true" Focusable="false" IsOpen="{Binding IsSubmenuOpen, RelativeSource={RelativeSource TemplatedParent}}" PopupAnimation="{DynamicResource {x:Static SystemParameters.MenuPopupAnimationKey}}" Placement="Bottom" VerticalOffset="-1">
                                <Border BorderThickness="0.5" BorderBrush="Gray" Background="#FF040406">
                                    <ScrollViewer x:Name="SubMenuScrollViewer" CanContentScroll="true" Style="{DynamicResource {ComponentResourceKey ResourceId=MenuScrollViewer, TypeInTargetAssembly={x:Type FrameworkElement}}}">
                                        <Grid RenderOptions.ClearTypeHint="Enabled">
                                            <ItemsPresenter x:Name="ItemsPresenter" KeyboardNavigation.DirectionalNavigation="Cycle" Grid.IsSharedSizeScope="true" Margin="2" SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" KeyboardNavigation.TabNavigation="Cycle" />
                                        </Grid>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True" />
                                    <Condition Property="IsChecked" Value="True" />
                                </MultiTrigger.Conditions>
                                <Setter Property="TextBlock.Foreground" Value="Green" TargetName="content" />
                            </MultiTrigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="TextBlock.Foreground" Value="LightGray" TargetName="content" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="TextBlock.Foreground" Value="SpringGreen" TargetName="content" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <hlp:FoundOnMapsToHeaderConverter x:Key="FoundOnMapsHeaderConverter" />
    </Window.Resources>
    <Border BorderBrush="#1b82e3" BorderThickness="0.5">
        <Grid>
            <Button x:Name="closeBtn" Style="{StaticResource RoundedCornerBtn}" BorderThickness="1" BorderBrush="White" HorizontalAlignment="Right" Height="25" VerticalAlignment="Top" Width="25" Foreground="{x:Null}" Click="closeBtn_Click" ToolTip="Close" Margin="0,5,5,0">
                <Button.Background>
                    <ImageBrush ImageSource="/Icons/closeIco.png"/>
                </Button.Background>
            </Button>
            <TabControl x:Name="settingsTabControl" Background="#1d1d1f" BorderThickness="0" Visibility="Visible" Panel.ZIndex="99" SelectionChanged="settingsTabControl_SelectionChanged" Margin="0,35,0,0">
                <TabControl.Resources>
                    <Style TargetType="{x:Type TabItem}">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="{x:Type TabItem}">
                                    <Grid>
                                        <Border Name="Border" Margin="0,0,0,0" Background="Black"
BorderBrush="White" BorderThickness="1,1,1,1" CornerRadius="5">
                                            <ContentPresenter x:Name="ContentSite" VerticalAlignment="Center"
            HorizontalAlignment="Center"
            ContentSource="Header" Margin="12,2,12,2"
            RecognizesAccessKey="True">
                                            </ContentPresenter>
                                        </Border>
                                    </Grid>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Panel.ZIndex" Value="100" />
                                            <Setter TargetName="Border" Property="Background" Value="Gray" />
                                            <Setter TargetName="Border" Property="BorderThickness" Value="1,1,1,1" />
                                            <Setter Property="Foreground" Value="White" />
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="False">
                                            <Setter Property="Foreground" Value="Gray" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </TabControl.Resources>
                <TabItem Header="Login">
                    <Grid>
                        <Label x:Name="loginLoginLabel" Content="Login" HorizontalAlignment="Left" Margin="10,10,0,0" VerticalAlignment="Top" Foreground="White" FontWeight="Bold" FontSize="18"/>
                        <Label x:Name="loginUsernamLabel" Content="Username:" HorizontalAlignment="Left" Margin="320,244,0,0" VerticalAlignment="Top" Foreground="White"/>
                        <TextBox x:Name="loginUsernameTextbox" HorizontalAlignment="Center" Margin="0,248,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="214" Text="{Binding Api.Settings.Username}"/>
                        <Label x:Name="loginPasswordLabel" Content="Password:" HorizontalAlignment="Left" Margin="320,275,0,0" VerticalAlignment="Top" Foreground="White"/>
                        <PasswordBox x:Name="loginPasswordBox" HorizontalAlignment="Center" Margin="0,279,0,0" VerticalAlignment="Top" Width="214" PasswordChanged="loginPasswordBox_PasswordChanged"/>
                        <CheckBox x:Name="loginAutoLoginCheckbox" Content="Auto Login" HorizontalAlignment="Left" Margin="245,303,0,0" VerticalAlignment="Top" Foreground="White" IsChecked="{Binding Api.Settings.AutoLogin}"/>
                        <Button x:Name="loginLoginBtn" Content="Login" HorizontalAlignment="Center" Margin="0,343,0,0" VerticalAlignment="Top" Width="214" Foreground="White" Background="Black" Click="loginLoginBtn_Click" Height="24">
                            <Button.Resources>
                                <Style TargetType="{x:Type Border}">
                                    <Setter Property="CornerRadius" Value="3"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                        <CheckBox x:Name="loginAutoStartCheckbox" Content="Auto Start" HorizontalAlignment="Left" Margin="381,303,0,0" VerticalAlignment="Top" Foreground="White" IsChecked="{Binding Api.Settings.AutoStart}"/>
                        <Label x:Name="loginSessionIdLabel" Content="SessionId:" HorizontalAlignment="Left" Margin="10,0,0,11" VerticalAlignment="Bottom" Foreground="White" IsEnabled="False"/>
                        <TextBox x:Name="loginSessionIdTextbox" HorizontalAlignment="Left" Margin="81,0,0,13" VerticalAlignment="Bottom" Width="523" Text="{Binding Api.Settings.SessionId}" IsEnabled="False"/>
                        <Button x:Name="loginLoginSessionIdBtn" Content="Login" HorizontalAlignment="Left" Margin="609,0,0,10" VerticalAlignment="Bottom" Width="76" Foreground="White" Background="Black" Click="loginLoginSessionIdBtn_Click" Height="24" IsEnabled="False">
                            <Button.Resources>
                                <Style TargetType="{x:Type Border}">
                                    <Setter Property="CornerRadius" Value="3"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                        <CheckBox x:Name="loginSolveCaptchaCheckbox" Content="Solve Captcha, 2Captcha Api Key:" HorizontalAlignment="Center" Margin="0,372,0,0" VerticalAlignment="Top" Foreground="White" Checked="loginSolveCaptchaCheckbox_Checked"/>
                        <TextBox x:Name="loginSolveCaptchaApiKeyTextbox" HorizontalAlignment="Center" Margin="0,392,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="214" Text="{Binding Api.Settings.TwoCaptchaApiKey}" IsEnabled="False"/>
                        <CheckBox x:Name="loginUnityLoginCheckbox" Content="Use Unity" HorizontalAlignment="Left" Margin="245,323,0,0" VerticalAlignment="Top" Foreground="White" IsChecked="{Binding Api.Settings.IsUnity}"/>
                        <CheckBox x:Name="loginLoggingCheckbox" Content="Create Log file" HorizontalAlignment="Left" Margin="10,579,0,0" VerticalAlignment="Top" Foreground="White" Checked="loginLoggingCheckbox_Checked" IsChecked="{Binding Api.Settings.CreateLog}"/>
                    </Grid>
                </TabItem>
                <TabItem Header="General">
                    <Grid>
                        <Label x:Name="generalGeneralLabel" Content="General" HorizontalAlignment="Left" Margin="10,10,0,0" VerticalAlignment="Top" Foreground="White" FontWeight="Bold" FontSize="18"/>
                        <!-- <CheckBox x:Name="generalGeneralRoamConfig" Style="{StaticResource OrangeSwitchStyle}" HorizontalAlignment="Left" Margin="100,54,0,0" VerticalAlignment="Top" Foreground="White" Background="{x:Null}" Checked="generalGeneralRoamConfig_Checked"/> -->
                        <Button x:Name="generalGeneralRoamConfig" d:Content="1" Content="{Binding Api.Settings.RoamConfig}" FontWeight="Bold" Foreground="White" HorizontalAlignment="Left" Margin="100,54,0,0" VerticalAlignment="Top" Background="{x:Null}" Click="generalGeneralRoamConfig_Click" BorderBrush="{x:Null}" />
                        <!-- <CheckBox x:Name="generalGeneralRepairConfig" Style="{StaticResource OrangeSwitchStyle}" HorizontalAlignment="Left" Margin="100,85,0,0" VerticalAlignment="Top" Foreground="White" Background="{x:Null}" Checked="generalGeneralRepairConfig_Checked"/> -->
                        <Button x:Name="generalGeneralRepairConfig" d:Content="1" Content="{Binding Api.Settings.RepairConfig}" FontWeight="Bold" Foreground="White" HorizontalAlignment="Left" Margin="100,85,0,0" VerticalAlignment="Top" Background="{x:Null}" Click="generalGeneralRepairConfig_Click" BorderBrush="{x:Null}" />
                        <Label x:Name="generalGeneralRepairAtLabel" Content="Repair At:" HorizontalAlignment="Left" Margin="10,110,0,0" VerticalAlignment="Top" Foreground="White"/>
                        <Label x:Name="generalGeneralRoamConfigLabel" Content="Roam Config:" HorizontalAlignment="Left" Margin="10,48,0,0" VerticalAlignment="Top" Foreground="White"/>
                        <Label x:Name="generalGeneralRepairConfigLabel" Content="Repair Config:" HorizontalAlignment="Left" Margin="10,79,0,0" VerticalAlignment="Top" Foreground="White"/>
                        <Slider x:Name="generalGeneralRepairAtSlider" HorizontalAlignment="Left" Margin="78,112,0,0" VerticalAlignment="Top" Width="120" LargeChange="10" SmallChange="1" TickFrequency="10" Maximum="100" TickPlacement="BottomRight" Value="{Binding Api.Settings.RepairAt}"/>
                        <Label x:Name="generalGeneralRepairFormationLabel" Content="Formattion:" HorizontalAlignment="Left" Margin="131,79,0,0" VerticalAlignment="Top" Foreground="White"/>
                        <Label x:Name="generalGeneralRoamFormationLabel" Content="Formattion:" HorizontalAlignment="Left" Margin="131,48,0,0" VerticalAlignment="Top" Foreground="White"/>
                        <ComboBox x:Name="generalGeneralRoamFormationCombobox" HorizontalAlignment="Left" Margin="207,53,0,0" VerticalAlignment="Top" Width="177" ItemsSource="{Binding Source={x:Static cmds:CommandConstants.DRONE_FORMATIONS}}" DisplayMemberPath="Key" SelectedValuePath="Value" SelectedValue="{Binding Api.Settings.RoamFormation}"/>
                        <ComboBox x:Name="generalGeneralRepairFormationCombobox" HorizontalAlignment="Left" Margin="207,85,0,0" VerticalAlignment="Top" Width="177" ItemsSource="{Binding Source={x:Static cmds:CommandConstants.DRONE_FORMATIONS}}" DisplayMemberPath="Key" SelectedValuePath="Value" SelectedValue="{Binding Api.Settings.RepairFormation}"/>
                        <Label x:Name="generalPetLabel" Content="Pet" HorizontalAlignment="Left" Margin="412,10,0,0" VerticalAlignment="Top" Foreground="White" FontWeight="Bold" FontSize="18"/>
                        <CheckBox x:Name="generalPetActivateCheckbox" Content="Use Pet" Margin="431,54,0,0" VerticalAlignment="Top" HorizontalAlignment="Left" Foreground="White" IsChecked="{Binding Api.Settings.PetUse}"/>
                        <Label x:Name="generalPetModeLabel" Content="Gear:" Margin="509,51,0,0" VerticalAlignment="Top" HorizontalAlignment="Left" Foreground="White"/>
                        <ComboBox x:Name="generalPetModeCombobox" HorizontalAlignment="Left" Margin="558,53,0,0" VerticalAlignment="Top" Width="118" ItemsSource="{Binding Source={x:Static cmds:CommandConstants.PET_MODES}}" DisplayMemberPath="Value" SelectedValuePath="Key" SelectedValue="{Binding Api.Settings.PetMode}" SelectionChanged="generalPetModeCombobox_SelectionChanged"/>
                        <Label x:Name="generalGeneralReviveLabel" Content="Revive:" HorizontalAlignment="Left" Margin="10,178,0,0" VerticalAlignment="Top" Foreground="White"/>
                        <ComboBox x:Name="comboBox" HorizontalAlignment="Left" Margin="66,180,0,0" VerticalAlignment="Top" Width="128" SelectedIndex="{Binding Api.Settings.ReviveOption}">
                            <ComboBoxItem Content="At Base"/>
                            <ComboBoxItem Content="At Gate"/>
                            <ComboBoxItem Content="At Spot"/>
                        </ComboBox>
                        <Label x:Name="generalPauseLabel" Content="Pause" HorizontalAlignment="Left" Margin="412,223,0,0" VerticalAlignment="Top" Foreground="White" FontWeight="Bold" FontSize="18"/>
                        <CheckBox x:Name="generalPauseUsePauseCheckbox" Content="Use Pause" Margin="431,264,0,0" VerticalAlignment="Top" HorizontalAlignment="Left" Foreground="White" IsChecked="{Binding Api.Settings.GeneralPauseUsePause}"/>
                        <Label x:Name="generalPausePauseTimeLabel" Content="Pause for:" HorizontalAlignment="Left" Margin="431,284,0,0" VerticalAlignment="Top" Foreground="White"/>
                        <Slider x:Name="generalPausePauseTimeSlider" HorizontalAlignment="Left" Margin="509,286,0,0" VerticalAlignment="Top" Width="120" LargeChange="1" SmallChange="0.5" TickFrequency="1" Maximum="12" TickPlacement="BottomRight" Value="{Binding Api.Settings.GeneralPausePauseTime}"/>
                        <Label x:Name="generalPausePauseAfterPlayTimeLabel" Content="Pause after:" HorizontalAlignment="Left" Margin="431,319,0,0" VerticalAlignment="Top" Foreground="White"/>
                        <Slider x:Name="generalPausePauseAfterPlayTimeSlider" HorizontalAlignment="Left" Margin="507,325,0,0" VerticalAlignment="Top" Width="120" LargeChange="1" SmallChange="0.5" TickFrequency="1" Maximum="12" TickPlacement="BottomRight" Value="{Binding Api.Settings.GeneralPauseAfterPlayTime}"/>
                        <Label x:Name="generalPausePauseAfterPlayTimeSuffixLabel" Content="Hours" HorizontalAlignment="Left" Margin="634,319,0,0" VerticalAlignment="Top" Foreground="White"/>
                        <Label x:Name="generalPausePauseTimeSuffixLabel" Content="Hours" HorizontalAlignment="Left" Margin="634,283,0,0" VerticalAlignment="Top" Foreground="White"/>
                        <CheckBox x:Name="generalAutoCloakCheckbox" Content="Auto Cloak" Margin="306,157,0,0" VerticalAlignment="Top" HorizontalAlignment="Left" Foreground="White" IsChecked="{Binding Api.Settings.GeneralAutoCloak}"/>
                        <Label x:Name="generalPausePauseTimeValueLabel" d:Content="5" Content="{Binding Api.Settings.GeneralPausePauseTime}" ContentStringFormat="{}{0:N2}" HorizontalAlignment="Left" Margin="561,303,0,0" VerticalAlignment="Top" Foreground="White"/>
                        <Label x:Name="generalPausePauseAfterPlayTimeValueLabel" d:Content="5"  Content="{Binding Api.Settings.GeneralPauseAfterPlayTime}" ContentStringFormat="{}{0:N2}" HorizontalAlignment="Left" Margin="561,342,0,0" VerticalAlignment="Top" Foreground="White"/>
