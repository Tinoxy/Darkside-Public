<CollectionViewSource x:Key="npcsList" Source="{Binding Api.Settings.NpcSettings}">
    <CollectionViewSource.GroupDescriptions>
        <!-- oberste Gruppierung: FoundOnMaps (0 = Lower, 1 = Upper, 2 = Other) -->
        <PropertyGroupDescription PropertyName="FoundOnMaps" />
        <!-- zweite Gruppierung: konkrete Map-Anzeige -->
        <PropertyGroupDescription PropertyName="DisplayFoundOnMapId" x:Name="npcsListMapGroup"/>
    </CollectionViewSource.GroupDescriptions>
    <CollectionViewSource.SortDescriptions>
        <scm:SortDescription PropertyName="FoundOnMapId" Direction="Ascending"/>
        <scm:SortDescription PropertyName="Name" Direction="Ascending"/>
    </CollectionViewSource.SortDescriptions>
</CollectionViewSource>
