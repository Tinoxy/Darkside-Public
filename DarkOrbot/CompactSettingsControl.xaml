                            </DataGrid.Columns>
                            <DataGrid.GroupStyle>
                                <!-- Äußere Gruppierung (FoundOnMaps) mit lesbarem Header via Converter -->
                                <GroupStyle>
                                    <GroupStyle.ContainerStyle>
                                        <Style TargetType="{x:Type GroupItem}">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="{x:Type GroupItem}">
                                                        <Expander IsExpanded="True" BorderBrush="Transparent" Background="Transparent" Foreground="#1b82e3">
                                                            <Expander.Header>
                                                                <TextBlock Text="{Binding Name, Converter={StaticResource FoundOnMapsHeaderConverter}}" Foreground="#1b82e3" FontWeight="Bold" FontSize="13" Padding="4,2"/>
                                                            </Expander.Header>
                                                            <Expander.Content>
                                                                <ItemsPresenter/>
                                                            </Expander.Content>
                                                        </Expander>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </GroupStyle.ContainerStyle>
                                </GroupStyle>

                                <!-- Innere Gruppierung (DisplayFoundOnMapId) wie vorher, aber in eigener GroupStyle -->
                                <GroupStyle>
                                    <GroupStyle.ContainerStyle>
                                        <Style TargetType="{x:Type GroupItem}">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="{x:Type GroupItem}">
                                                        <Expander IsExpanded="True" >
                                                            <Expander.Header>
                                                                <DockPanel>
