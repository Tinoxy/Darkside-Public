<UserControl x:Class="DarkOrbot.CompactApiControl"
           xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
           xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
           xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
           xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
           xmlns:scm="clr-namespace:System.ComponentModel;assembly=WindowsBase"
           xmlns:obj="clr-namespace:DarksideApi.DarkOrbit;assembly=DarksideApi"
           xmlns:hlp="clr-namespace:DarkOrbot.Util"
           xmlns:stats="clr-namespace:DarksideApi.Statistics;assembly=DarksideApi"
           xmlns:cmds="clr-namespace:DarksideApi.DarkOrbit.Commands;assembly=DarksideApi"
           xmlns:settings="clr-namespace:DarksideApi.DarkOrbit.Settings;assembly=DarksideApi"
           xmlns:local="clr-namespace:DarkOrbot"
           mc:Ignorable="d" d:DesignWidth="540" Height="320" Width="540" Loaded="UserControl_Loaded" Unloaded="UserControl_Unloaded" Background="#1d1d1f"
  DataContext="{Binding RelativeSource={RelativeSource Self}}" VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
    <!--ACTIVE COLOR: #1b82e3 BACKGROUND COLOR: #1d1d1f-->
    <UserControl.Resources>

        <BooleanToVisibilityConverter x:Key="BoolToVis" />

        <Style TargetType="{x:Type ToolTip}">
            <Setter Property="Background" Value="#FF040406" />
            <Setter Property="Foreground" Value="White" />
        </Style>

        <Style TargetType="{x:Type TabItem}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type TabItem}">
                        <Grid>
                            <Border Name="Border" Margin="0,0,0,0" Background="Black"
BorderBrush="White" BorderThickness="1,1,1,1" CornerRadius="5">
                                <ContentPresenter x:Name="ContentSite" VerticalAlignment="Center"
            HorizontalAlignment="Center"
            ContentSource="Header" Margin="12,2,12,2"
            RecognizesAccessKey="True">
                                </ContentPresenter>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Panel.ZIndex" Value="100" />
                                <Setter TargetName="Border" Property="Background" Value="Gray" />
                                <Setter TargetName="Border" Property="BorderThickness" Value="1,1,1,1" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="False">
                                <Setter Property="Foreground" Value="Gray" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style BasedOn="{StaticResource {x:Type DataGridColumnHeader}}" TargetType="{x:Type DataGridColumnHeader}">
            <Setter Property="Background" >
                <Setter.Value>
                    <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                        <GradientStop Color="Black" Offset="0.9"/>
                        <GradientStop Color="#FF030304" Offset="1"/>
                        <GradientStop Color="Black" Offset="0"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="generalStartBtnStyle" TargetType="{x:Type Button}">
            <Setter Property="Foreground" Value="Transparent"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding Api.Settings.IsRunning}" Value="false">
                    <Setter Property="Background">
                        <Setter.Value>
                            <ImageBrush ImageSource="/Icons/playIco.png"/>
                        </Setter.Value>
                    </Setter>
                </DataTrigger>
                <DataTrigger Binding="{Binding Api.Settings.IsRunning}" Value="true">
                    <Setter Property="Background">
                        <Setter.Value>
                            <ImageBrush ImageSource="/Icons/pauseIco.png"/>
                        </Setter.Value>
                    </Setter>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="generalShootNpcsBtnStyle" TargetType="{x:Type Button}">
            <Setter Property="Foreground" Value="Transparent"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding Api.Settings.GeneralShootNpcs}" Value="false">
                    <Setter Property="Background">
                        <Setter.Value>
                            <ImageBrush ImageSource="/Icons/npcIcoActv.png"/>
                        </Setter.Value>
                    </Setter>
                </DataTrigger>
                <DataTrigger Binding="{Binding Api.Settings.GeneralShootNpcs}" Value="true">
                    <Setter Property="Background">
                        <Setter.Value>
                            <ImageBrush ImageSource="/Icons/npcIcoGlow.png"/>
                        </Setter.Value>
                    </Setter>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="generalCollectBoxesBtnStyle" TargetType="{x:Type Button}">
            <Setter Property="Foreground" Value="Transparent"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding Api.Settings.GeneralCollectBoxes}" Value="false">
                    <Setter Property="Background">
                        <Setter.Value>
                            <ImageBrush ImageSource="/Icons/boxIcoActv.png"/>
                        </Setter.Value>
                    </Setter>
                </DataTrigger>
                <DataTrigger Binding="{Binding Api.Settings.GeneralCollectBoxes}" Value="true">
                    <Setter Property="Background">
                        <Setter.Value>
                            <ImageBrush ImageSource="/Icons/boxIcoGlow.png"/>
                        </Setter.Value>
                    </Setter>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="generalHideGameBtnStyle" TargetType="{x:Type Button}">
            <Setter Property="Foreground" Value="Transparent"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding Api.Settings.IsMinimapShown}" Value="false">
                    <Setter Property="Background">
                        <Setter.Value>
                            <ImageBrush ImageSource="/Icons/showIco.png"/>
                        </Setter.Value>
                    </Setter>
                </DataTrigger>
                <DataTrigger Binding="{Binding Api.Settings.IsMinimapShown}" Value="true">
                    <Setter Property="Background">
                        <Setter.Value>
                            <ImageBrush ImageSource="/Icons/hideIco.png"/>
                        </Setter.Value>
                    </Setter>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="generalDoGalaxyGatesBtnStyle" TargetType="{x:Type Button}">
            <Setter Property="Foreground" Value="Transparent"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding Api.Settings.GeneralDoGalaxyGates}" Value="false">
                    <Setter Property="Background">
                        <Setter.Value>
                            <ImageBrush ImageSource="/Icons/ggIcoActv.png"/>
                        </Setter.Value>
                    </Setter>
                </DataTrigger>
                <DataTrigger Binding="{Binding Api.Settings.GeneralDoGalaxyGates}" Value="true">
                    <Setter Property="Background">
                        <Setter.Value>
                            <ImageBrush ImageSource="/Icons/ggIcoGlow.png"/>
                        </Setter.Value>
                    </Setter>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="generalShowFullMapBtnStyle" TargetType="{x:Type Button}">
            <Setter Property="Foreground" Value="Transparent"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding Api.Settings.IsMinimapPlayerView}" Value="false">
                    <Setter Property="Background">
                        <Setter.Value>
                            <ImageBrush ImageSource="/Icons/fullMapIco.png"/>
                        </Setter.Value>
                    </Setter>
                </DataTrigger>
                <DataTrigger Binding="{Binding Api.Settings.IsMinimapPlayerView}" Value="true">
                    <Setter Property="Background">
                        <Setter.Value>
                            <ImageBrush ImageSource="/Icons/playerMapIco.png"/>
                        </Setter.Value>
                    </Setter>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="generalPassiveShootNpcsBtnStyle" TargetType="{x:Type Button}">
            <Setter Property="Foreground" Value="Transparent"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding Api.Settings.GeneralPassiveShootNpcs}" Value="false">
                    <Setter Property="Background">
                        <Setter.Value>
                            <ImageBrush ImageSource="/Icons/passiveIcoActv.png"/>
                        </Setter.Value>
                    </Setter>
                </DataTrigger>
                <DataTrigger Binding="{Binding Api.Settings.GeneralPassiveShootNpcs}" Value="true">
                    <Setter Property="Background">
                        <Setter.Value>
                            <ImageBrush ImageSource="/Icons/passiveIcoGlow.png"/>
                        </Setter.Value>
                    </Setter>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="generalLoginBtnStyle" TargetType="{x:Type Button}">
            <Setter Property="Foreground" Value="Transparent"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding Settings.IsLoggingIn}" Value="false">
                    <Setter Property="Background">
                        <Setter.Value>
                            <ImageBrush ImageSource="/Icons/loginIco.png"/>
                        </Setter.Value>
                    </Setter>
                </DataTrigger>
                <DataTrigger Binding="{Binding Settings.IsLoggingIn}" Value="true">
                    <Setter Property="Background">
                        <Setter.Value>
                            <ImageBrush ImageSource="/Icons/loginIcoGlow.png"/>
                        </Setter.Value>
                    </Setter>
                </DataTrigger>
                <DataTrigger Binding="{Binding Settings.IsInGame}" Value="true">
                    <Setter Property="Background">
                        <Setter.Value>
                            <ImageBrush ImageSource="/Icons/logoutIco.png"/>
                        </Setter.Value>
                    </Setter>
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="generalLoginToolTipStyle" TargetType="{x:Type ToolTip}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding Settings.IsLoggingIn}" Value="false">
                    <Setter Property="Content" Value="Login">
                    </Setter>
                </DataTrigger>
                <DataTrigger Binding="{Binding Settings.IsLoggingIn}" Value="true">
                    <Setter Property="Content" Value="Logging in...">
                    </Setter>
                </DataTrigger>
                <DataTrigger Binding="{Binding Settings.IsInGame}" Value="true">
                    <Setter Property="Content" Value="Logout">
                    </Setter>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ScrollBarLineButton" TargetType="{x:Type RepeatButton}">
            <Setter Property="Visibility" Value="Hidden"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="OverridesDefaultStyle" Value="true"/>
            <Setter Property="Focusable" Value="false"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type RepeatButton}">
                        <Border Name="Border" Margin="1" CornerRadius="2" Background="#7F040406" BorderBrush="Gray" BorderThickness="1">
                            <Path HorizontalAlignment="Center" VerticalAlignment="Center" Fill="White" Data="{Binding Path=Content, RelativeSource={RelativeSource TemplatedParent}}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsPressed" Value="true">
                                <Setter TargetName="Border" Property="Background" Value="WhiteSmoke" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="false">
                                <Setter Property="Foreground" Value="DarkGray"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ScrollBarPageButton" TargetType="{x:Type RepeatButton}">
            <Setter Property="Visibility" Value="Hidden"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="OverridesDefaultStyle" Value="true"/>
            <Setter Property="IsTabStop" Value="false"/>
            <Setter Property="Focusable" Value="false"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type RepeatButton}">
                        <Border Background="DimGray" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ScrollBarThumb" TargetType="{x:Type Thumb}">
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="OverridesDefaultStyle" Value="true"/>
            <Setter Property="IsTabStop" Value="false"/>
            <Setter Property="Focusable" Value="false"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Thumb}">
                        <Border CornerRadius="4" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="0"  Width="8" Margin="8,0,-2,0"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <ControlTemplate x:Key="VerticalScrollBar" TargetType="{x:Type ScrollBar}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition MaxHeight="0"/>
                    <RowDefinition Height="0.00001*"/>
                    <RowDefinition MaxHeight="0"/>
                </Grid.RowDefinitions>
                <Border Grid.RowSpan="3" CornerRadius="2" Background="Transparent" />
                <RepeatButton Grid.Row="0" Style="{StaticResource ScrollBarLineButton}" Height="18" Command="ScrollBar.LineUpCommand" Content="M 0 4 L 8 4 L 4 0 Z" />
                <Track Name="PART_Track" Grid.Row="1" IsDirectionReversed="true">
                    <Track.DecreaseRepeatButton>
                        <RepeatButton Style="{StaticResource ScrollBarPageButton}" Command="ScrollBar.PageUpCommand" />
                    </Track.DecreaseRepeatButton>
                    <Track.Thumb>
                        <Thumb Style="{StaticResource ScrollBarThumb}" Margin="1,0,1,0" Background="#7F040406" BorderBrush="Gray" />
                    </Track.Thumb>
                    <Track.IncreaseRepeatButton>
                        <RepeatButton Style="{StaticResource ScrollBarPageButton}" Command="ScrollBar.PageDownCommand" />
                    </Track.IncreaseRepeatButton>
                </Track>
                <RepeatButton Grid.Row="3" Style="{StaticResource ScrollBarLineButton}" Height="18" Command="ScrollBar.LineDownCommand" Content="M 0 0 L 4 4 L 8 0 Z"/>
            </Grid>
        </ControlTemplate>
        <ControlTemplate x:Key="HorizontalScrollBar" TargetType="{x:Type ScrollBar}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition MaxWidth="18"/>
                    <ColumnDefinition Width="0.00001*"/>
                    <ColumnDefinition MaxWidth="18"/>
                </Grid.ColumnDefinitions>
                <Border Grid.ColumnSpan="3" CornerRadius="2" Background="Transparent"/>
                <RepeatButton Grid.Column="0"  Style="{StaticResource ScrollBarLineButton}" Width="18" Command="ScrollBar.LineLeftCommand" Content="M 4 0 L 4 8 L 0 4 Z" />
                <Track Name="PART_Track" Grid.Column="1" IsDirectionReversed="False">
                    <Track.DecreaseRepeatButton>
                        <RepeatButton Style="{StaticResource ScrollBarPageButton}" Command="ScrollBar.PageLeftCommand" />
                    </Track.DecreaseRepeatButton>
                    <Track.Thumb>
                        <Thumb Style="{StaticResource ScrollBarThumb}" Margin="0,1,0,1" Background="#7F040406" BorderBrush="Gray" />
                    </Track.Thumb>
                    <Track.IncreaseRepeatButton>
                        <RepeatButton Style="{StaticResource ScrollBarPageButton}" Command="ScrollBar.PageRightCommand" />
                    </Track.IncreaseRepeatButton>
                </Track>
                <RepeatButton Grid.Column="3" Style="{StaticResource ScrollBarLineButton}" Width="18" Command="ScrollBar.LineRightCommand" Content="M 0 0 L 4 4 L 0 8 Z"/>
            </Grid>
        </ControlTemplate>
        <Style x:Key="{x:Type ScrollBar}" TargetType="{x:Type ScrollBar}">
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="OverridesDefaultStyle" Value="true"/>
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Horizontal">
                    <Setter Property="Width" Value="Auto"/>
                    <Setter Property="Height" Value="18" />
                    <Setter Property="Template" Value="{StaticResource HorizontalScrollBar}" />
                </Trigger>
                <Trigger Property="Orientation" Value="Vertical">
                    <Setter Property="Width" Value="18"/>
                    <Setter Property="Height" Value="Auto" />
                    <Setter Property="Template" Value="{StaticResource VerticalScrollBar}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="FavsScrollViewer" TargetType="{x:Type ScrollViewer}">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ScrollViewer}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <ScrollContentPresenter Grid.Column="1"/>
                            <ScrollBar Name="PART_VerticalScrollBar" Value="{TemplateBinding VerticalOffset}" Maximum="{TemplateBinding ScrollableHeight}" ViewportSize="{TemplateBinding ViewportHeight}" Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"/>
                            <ScrollBar Name="PART_HorizontalScrollBar" Orientation="Horizontal" Grid.Row="1" Grid.Column="1" Value="{TemplateBinding HorizontalOffset}" Maximum="{TemplateBinding ScrollableWidth}" ViewportSize="{TemplateBinding ViewportWidth}" Visibility="{TemplateBinding ComputedHorizontalScrollBarVisibility}"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="{x:Type ContextMenu}">
            <Setter Property="Background" Value="#1d1d1f" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Opacity" Value="75" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="OverridesDefaultStyle" Value="True" />
            <Setter Property="HasDropShadow" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ContextMenu}">
                        <Border x:Name="Border" Background="{TemplateBinding Background}" BorderBrush="Gray" Opacity="{TemplateBinding Opacity}" BorderThickness="0.5" CornerRadius="3">
                            <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Cycle">
                            </StackPanel>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="{x:Type MenuItem}">
            <Setter Property="Background" Value="#1d1d1f" />
            <Setter Property="BorderThickness" Value="0.5" />
            <Setter Property="BorderBrush" Value="Gray" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type MenuItem}">
                        <Grid SnapsToDevicePixels="true">
                            <Border BorderBrush="Gray" BorderThickness="0.5" CornerRadius="3">

                                <DockPanel>
                                    <ContentPresenter x:Name="Icon" ContentSource="Icon" Margin="4,0,6,0" SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" VerticalAlignment="Center" />
                                    <Path x:Name="GlyphPanel" Fill="{TemplateBinding Foreground}" FlowDirection="LeftToRight" Margin="7,0,0,0" Visibility="Collapsed" VerticalAlignment="Center" />
                                    <ContentPresenter x:Name="content" ContentSource="Header" RecognizesAccessKey="True" SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                                </DockPanel>
                            </Border>
                            <Popup x:Name="PART_Popup" AllowsTransparency="true" Focusable="false" IsOpen="{Binding IsSubmenuOpen, RelativeSource={RelativeSource TemplatedParent}}" PopupAnimation="{DynamicResource {x:Static SystemParameters.MenuPopupAnimationKey}}" Placement="Bottom" VerticalOffset="-1">
                                <Border BorderThickness="0.5" BorderBrush="Gray" Background="#1d1d1f">
                                    <ScrollViewer x:Name="SubMenuScrollViewer" CanContentScroll="true" Style="{DynamicResource {ComponentResourceKey ResourceId=MenuScrollViewer, TypeInTargetAssembly={x:Type FrameworkElement}}}">
                                        <Grid RenderOptions.ClearTypeHint="Enabled">
                                            <ItemsPresenter x:Name="ItemsPresenter" KeyboardNavigation.DirectionalNavigation="Cycle" Grid.IsSharedSizeScope="true" Margin="2" SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" KeyboardNavigation.TabNavigation="Cycle" />
                                        </Grid>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True" />
                                    <Condition Property="IsChecked" Value="True" />
                                </MultiTrigger.Conditions>
                                <Setter Property="TextBlock.Foreground" Value="#1b82e3" TargetName="content" />
                            </MultiTrigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="TextBlock.Foreground" Value="LightGray" TargetName="content" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="TextBlock.Foreground" Value="#1b82e3" TargetName="content" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </UserControl.Resources>
    <Grid>
        <Grid>
            <Grid.Resources>
                <CollectionViewSource x:Key="availableMenuItemsList" Source="{Binding Api.Menu.AvailableMenuItems}">
                    <CollectionViewSource.GroupDescriptions>
                        <PropertyGroupDescription PropertyName="Type" x:Name="availableMenuItemsGroup"/>
                    </CollectionViewSource.GroupDescriptions>
                    <CollectionViewSource.SortDescriptions>
                        <scm:SortDescription PropertyName="Id" Direction="Descending"/>
                    </CollectionViewSource.SortDescriptions>
                </CollectionViewSource>
            </Grid.Resources>
            <Button x:Name="generalStartBtn" Style="{StaticResource generalStartBtnStyle}" HorizontalAlignment="Left" Height="45" Margin="10,10,0,0" VerticalAlignment="Top" Width="46" Foreground="{x:Null}" Click="generalStartBtn_Click" BorderBrush="{x:Null}" ToolTip="Start/Stop">
                <d:Button.Background>
                    <ImageBrush ImageSource="/Icons/playIco.png"/>
                </d:Button.Background>
            </Button>
            <Canvas x:Name="generalGameCanvas" d:Background="Black" Height="200" Width="420" MouseDown="generalGameCanvas_MouseDown" MouseUp="generalGameCanvas_MouseUp" MouseWheel="generalGameCanvas_MouseWheel" MouseMove="generalGameCanvas_MouseMove" ClipToBounds="True" Margin="60,60,60,60">
                <Canvas.ContextMenu>
                    <ContextMenu x:Name="generalGameCanvasContextMenu" Opacity="75">
                        <MenuItem Header="Jump" Click="MenuItemJump_Click"></MenuItem>
                        <MenuItem Header="Use Item" ItemsSource="{Binding Source={StaticResource availableMenuItemsList}}" DisplayMemberPath="DisplayName" Click="MenuItemUse_Click"></MenuItem>
                        <MenuItem Header="Validate Boxes" Click="MenuItemValidateBoxes_Click"></MenuItem>
                        <Separator/>
                        <MenuItem Header="Show Background" IsChecked="{Binding Api.Settings.MinimapShowBackground}" IsCheckable="True"></MenuItem>
                        <MenuItem Header="Show Boxes" IsChecked="{Binding Api.Settings.MinimapShowBoxes}" IsCheckable="True"></MenuItem>
                        <MenuItem Header="Show Ores" IsChecked="{Binding Api.Settings.MinimapShowOres}" IsCheckable="True"></MenuItem>
                        <MenuItem Header="Show Npcs" IsChecked="{Binding Api.Settings.MinimapShowNpcs}" IsCheckable="True"></MenuItem>
                        <MenuItem Header="Show Npc Names" IsChecked="{Binding Api.Settings.MinimapShowNpcNames}" IsCheckable="True"></MenuItem>
                        <MenuItem Header="Show Players" IsChecked="{Binding Api.Settings.MinimapShowPlayers}" IsCheckable="True"></MenuItem>
                        <MenuItem Header="Show Player Names" IsChecked="{Binding Api.Settings.MinimapShowPlayerNames}" IsCheckable="True"></MenuItem>
                        <MenuItem Header="Show Gates" IsChecked="{Binding Api.Settings.MinimapShowGates}" IsCheckable="True"></MenuItem>
                        <MenuItem Header="Show Assets" IsChecked="{Binding Api.Settings.MinimapShowBuildings}" IsCheckable="True"></MenuItem>
                        <MenuItem Header="Show Pets" IsChecked="{Binding Api.Settings.MinimapShowPet}" IsCheckable="True"></MenuItem>
                        <MenuItem Header="Show Mines" IsChecked="{Binding Api.Settings.MinimapShowMines}" IsCheckable="True"></MenuItem>
                        <MenuItem Header="Show Zones" IsChecked="{Binding Api.Settings.MinimapShowZones}" IsCheckable="True"></MenuItem>
                        <MenuItem Header="Show Workarea" IsChecked="{Binding Api.Settings.MinimapShowWorkArea}" IsCheckable="True"></MenuItem>
                    </ContextMenu>
                </Canvas.ContextMenu>
            </Canvas>
            <Button x:Name="generalCollectBoxesBtn" Style="{StaticResource generalCollectBoxesBtnStyle}" HorizontalAlignment="Left" Height="45" Margin="10,265,0,0" VerticalAlignment="Top" Width="46" Foreground="{x:Null}" BorderBrush="{x:Null}" Click="generalCollectBoxesBtn_Click" ToolTip="Collect Boxes On/Off">
                <d:Button.Background>
                    <ImageBrush ImageSource="/Icons/boxIcoActv.png"/>
                </d:Button.Background>
            </Button>
            <Button x:Name="generalShootNpcsBtn" Style="{StaticResource generalShootNpcsBtnStyle}" HorizontalAlignment="Left" Height="45" Margin="61,265,0,0" VerticalAlignment="Top" Width="46" Foreground="{x:Null}" BorderBrush="{x:Null}" Click="generalShootNpcsBtn_Click" ToolTip="Shoot Npcs On/Off">
                <d:Button.Background>
                    <ImageBrush ImageSource="/Icons/npcIcoActv.png"/>
                </d:Button.Background>
            </Button>
            <Button x:Name="generalRemoveApiBtn" HorizontalAlignment="Right" Height="45" Margin="0,10,10,0" VerticalAlignment="Top" Width="45" Foreground="{x:Null}" Click="generalRemoveApiBtn_Click" BorderBrush="{x:Null}" ToolTip="Remove Account">
                <Button.Background>
                    <ImageBrush ImageSource="/Icons/removeIco.png"/>
                </Button.Background>
            </Button>
            <Button x:Name="generalLogoutApiBtn" Style="{StaticResource generalLoginBtnStyle}" HorizontalAlignment="Right" Height="45" Margin="0,10,434,0" VerticalAlignment="Top" Width="45" Foreground="{x:Null}" Click="generalLogoutApiBtn_Click" BorderBrush="{x:Null}" ToolTip="Login">
                <d:Button.Background>
                    <ImageBrush ImageSource="/Icons/logoutIco.png"/>
                </d:Button.Background>
                <Button.Resources>
                    <Style TargetType="{x:Type ToolTip}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Settings.IsLoggingIn}" Value="false">
                                <Setter Property="Content" Value="Login">
                                </Setter>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Settings.IsLoggingIn}" Value="true">
                                <Setter Property="Content" Value="Logging in...">
                                </Setter>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Settings.IsInGame}" Value="true">
                                <Setter Property="Content" Value="Logout">
                                </Setter>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Resources>
            </Button>
            <Button x:Name="generalDoGalaxyGatesBtn" Style="{StaticResource generalDoGalaxyGatesBtnStyle}" HorizontalAlignment="Left" Height="45" Margin="112,265,0,0" VerticalAlignment="Top" Width="46" Foreground="{x:Null}" BorderBrush="{x:Null}" Click="generalDoGalaxyGatesBtn_Click" ToolTip="Do GalaxyGates On/Off">
                <d:Button.Background>
                    <ImageBrush ImageSource="/Icons/ggIcoActv.png"/>
